  },
  "devDependencies": {
    "@gw2treasures/eslint-config": "workspace:*",
    "@gw2treasures/tsconfig": "workspace:*",
    "@types/node": "24.13.2",
    "eslint": "10.5.0",
    "prisma": "7.8.0",
    "typescript": "6.0.3"
  }
}
