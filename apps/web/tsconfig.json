{
  "extends": "@gw2treasures/tsconfig/nextjs",
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "paths": {
      "@/app/*": ["./app/*"],
      "@/components/*": ["./components/*"],
      "@/data/*": ["./data/*"],
      "@/lib/*": ["./lib/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/.well-known/**/*.ts",
    ".next/types/**/*.ts",
    "vitest.config.mts",
  ],
}
